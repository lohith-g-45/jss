# API Configuration
VITE_API_URL=http://localhost:5000/api
VITE_AI_API_URL=http://localhost:8000/api

# ── BioDigital Human 3D Viewer ─────────────────────────────────────────────
# Get your developer key (Client ID) at: https://developer.biodigital.com
# 1. Register a free developer account
# 2. Create an app and add localhost:5173 to allowed domains
# 3. Copy the Client ID and paste it here
# 4. Restart the dev server
VITE_BIODIGITAL_CLIENT_ID=

